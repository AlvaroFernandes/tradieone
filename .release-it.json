{
  "$schema": "https://unpkg.com/release-it@20/schema/release-it.json",
  "git": {
    "commitMessage": "chore: release v${version}",
    "tagName": "v${version}",
    "requireBranch": false,
    "requireCleanWorkingDir": true
  },
  "github": {
    "release": false
  },
  "npm": {
    "publish": false
  },
  "plugins": {
    "@release-it/conventional-changelog": {
      "preset": {
        "name": "conventionalcommits",
        "types": [
          { "type": "feat",     "section": "✨ Features" },
          { "type": "fix",      "section": "🐛 Bug Fixes" },
          { "type": "perf",     "section": "⚡ Performance" },
          { "type": "refactor", "section": "♻️ Refactoring" },
          { "type": "docs",     "section": "📚 Documentation" },
          { "type": "build",    "section": "🏗️ Build", "hidden": true },
          { "type": "ci",       "section": "👷 CI", "hidden": true },
          { "type": "chore",    "section": "🔧 Chores", "hidden": true },
          { "type": "style",    "section": "💅 Style", "hidden": true },
          { "type": "test",     "section": "✅ Tests", "hidden": true }
        ]
      },
      "infile": "CHANGELOG.md",
      "header": "# Changelog\n\nAll notable changes to TradieOne are documented here.\nThis project adheres to [Semantic Versioning](https://semver.org/spec/v2.0.0.html) and [Conventional Commits](https://www.conventionalcommits.org/).\n"
    }
  }
}
